{% extends "base.html.j2" %}

{% block title %}Role Management - ASP.NET Core Community{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Role Management</h2>
        <a href="{{ url_for('admin.create_role') }}" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Role
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Role Name</th>
                        <th>Description</th>
                        <th>Users Count</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for role in roles %}
                    <tr>
                        <td>{{ role.id }}</td>
                        <td><strong>{{ role.name }}</strong></td>
                        <td>{{ role.description or 'No description' }}</td>
                        <td>
                            <span class="badge bg-secondary">{{ role.users.count() }} users</span>
                        </td>
                        <td>
                            <a href="{{ url_for('admin.edit_role', id=role.id) }}" 
                               class="btn btn-sm btn-outline-primary me-2">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            
                            {% if role.users.count() == 0 %}
                            <form method="POST" 
                                  action="{{ url_for('admin.delete_role', id=role.id) }}" 
                                  style="display:inline;"
                                  onsubmit="return confirm('Delete this role? This action cannot be undone.')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                            {% else %}
                            <button class="btn btn-sm btn-outline-secondary" disabled>
                                <i class="fas fa-trash"></i> Cannot Delete
                            </button>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            No roles found.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}