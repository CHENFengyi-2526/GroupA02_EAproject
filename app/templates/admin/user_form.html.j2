{% extends "base.html.j2" %}

{% block title %}
    {% if user %}Edit User{% else %}Create New User{% endif %} - Admin
{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3>
                        <i class="fas fa-user me-2"></i>
                        {% if user %}Edit User{% else %}Create New User{% endif %}
                    </h3>
                </div>
                <div class="card-body p-5">
                    <form method="POST">
                        {{ form.hidden_tag() }}

                        <div class="row">
                            <!-- Username -->
                            <div class="col-md-6 mb-4">
                                {{ form.username.label(class="form-label fw-semibold") }}
                                {{ form.username(class="form-control") }}
                                {% for error in form.username.errors %}
                                    <div class="text-danger small mt-1">{{ error }}</div>
                                {% endfor %}
                            </div>

                            <!-- Email -->
                            <div class="col-md-6 mb-4">
                                {{ form.email.label(class="form-label fw-semibold") }}
                                {{ form.email(class="form-control") }}
                                {% for error in form.email.errors %}
                                    <div class="text-danger small mt-1">{{ error }}</div>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            {{ form.password.label(class="form-label fw-semibold") }}
                            {{ form.password(class="form-control", placeholder="Leave blank to keep current password (edit mode)") }}
                            {% for error in form.password.errors %}
                                <div class="text-danger small mt-1">{{ error }}</div>
                            {% endfor %}
                            {% if user %}
                                <small class="text-muted">Leave empty if you don't want to change password</small>
                            {% endif %}
                        </div>

                        <!-- Role -->
                        <div class="mb-4">
                            {{ form.role.label(class="form-label fw-semibold") }}
                            {{ form.role(class="form-select") }}
                            {% for error in form.role.errors %}
                                <div class="text-danger small mt-1">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3">
                            <a href="{{ url_for('admin.list_users') }}" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-purple btn-lg px-5">
                                <i class="fas fa-save me-2"></i>
                                {% if user %}Update User{% else %}Create User{% endif %}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}