{% extends "base.html.j2" %}

{% block title %}{{ 'Edit' if category else 'Create' }} Category{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3>{{ 'Edit Category' if category else 'Create New Category' }}</h3>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        {{ form.hidden_tag() }}
                        
                        <div class="mb-3">
                            {{ form.name.label(class="form-label") }}
                            {{ form.name(class="form-control" + (' is-invalid' if form.name.errors else '')) }}
                            {% for error in form.name.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        </div>
                        
                        <div class="mb-3">
                            {{ form.slug.label(class="form-label") }}
                            {{ form.slug(class="form-control", placeholder="url-friendly-name") }}
                            <small class="text-muted">Used in URLs (e.g., /resources?category=url-friendly-name)</small>
                        </div>
                        
                        <div class="mb-3">
                            {{ form.icon.label(class="form-label") }}
                            {{ form.icon(class="form-control", placeholder="folder, book, video, code") }}
                            <small class="text-muted">Font Awesome icon name</small>
                        </div>
                        
                        <div class="mb-3">
                            {{ form.description.label(class="form-label") }}
                            {{ form.description(class="form-control", rows=3) }}
                        </div>
                        
                        <div class="mt-4">
                            {{ form.submit(class="btn btn-primary") }}
                            <a href="{{ url_for('resources.list_categories') }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}