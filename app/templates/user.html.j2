{% extends "base.html.j2" %}

{% block title %}{{ user.username }} - Profile - ASP.NET Core Community{% endblock %}

{% block content %}
<div class="container my-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body text-center">
                    <i class="fas fa-user-circle fa-5x text-purple mb-3"></i>
                    <h3>{{ user.username }}</h3>
                    <p class="text-muted">{{ user.email }}</p>
                    <p><small>Member since: {{ user.created_at.strftime('%B %d, %Y') if user.created_at else 'N/A' }}</small></p>
                    {% if current_user.id == user.id %}
                    <a href="{{ url_for('main.edit_profile') }}" class="btn btn-outline-purple btn-sm">
                        <i class="fas fa-edit me-1"></i>Edit Profile
                    </a>
                    {% endif %} 
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5>Recent Activity</h5>
                    <hr>
                    <p class="text-muted">No recent activity to display.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}