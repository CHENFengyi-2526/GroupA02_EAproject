{% extends "base.html.j2" %}

{% block title %}
    {% if role %}Edit Role{% else %}Create New Role{% endif %} - Admin
{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3>
                        <i class="fas fa-user-tag me-2"></i>
                        {% if role %}Edit Role{% else %}Create New Role{% endif %}
                    </h3>
                </div>
                <div class="card-body p-5">
                    <form method="POST">
                        {{ form.hidden_tag() }}

                        <!-- Role Name -->
                        <div class="mb-4">
                            {{ form.name.label(class="form-label fw-semibold") }}
                            {{ form.name(class="form-control") }}
                            {% for error in form.name.errors %}
                                <div class="text-danger small mt-1">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            {{ form.description.label(class="form-label fw-semibold") }}
                            {{ form.description(class="form-control", rows="3") }}
                            {% for error in form.description.errors %}
                                <div class="text-danger small mt-1">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3">
                            <a href="{{ url_for('admin.list_roles') }}" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-purple btn-lg px-5">
                                <i class="fas fa-save me-2"></i>
                                {% if role %}Update Role{% else %}Create Role{% endif %}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}