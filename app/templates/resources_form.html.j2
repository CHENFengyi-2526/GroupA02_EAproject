{% extends "base.html.j2" %}

{% block title %}{{ 'Edit' if resource else 'Create' }} Resource{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3>{{ 'Edit Resource' if resource else 'Upload New Resource' }}</h3>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        {{ form.hidden_tag() }}
                        
                        <div class="mb-3">
                            {{ form.title.label(class="form-label") }}
                            {{ form.title(class="form-control" + (' is-invalid' if form.title.errors else '')) }}
                            {% for error in form.title.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        </div>
                        
                        <div class="mb-3">
                            {{ form.description.label(class="form-label") }}
                            {{ form.description(class="form-control", rows=5) }}
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form.type.label(class="form-label") }}
                                {{ form.type(class="form-select") }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form.category_id.label(class="form-label") }}
                                {{ form.category_id(class="form-select") }}
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            {{ form.file_path.label(class="form-label") }}
                            {{ form.file_path(class="form-control", placeholder="File path or URL") }}
                            <small class="text-muted">Enter file path on server or external URL</small>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form.external_link.label(class="form-label") }}
                                {{ form.external_link(class="form-control", placeholder="https://...") }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form.file_size.label(class="form-label") }}
                                {{ form.file_size(class="form-control", placeholder="e.g., 2.5 MB") }}
                            </div>
                        </div>
                        
                        <div class="mb-3 form-check">
                            {{ form.is_featured(class="form-check-input") }}
                            {{ form.is_featured.label(class="form-check-label") }}
                        </div>
                        
                        <div class="mt-4">
                            {{ form.submit(class="btn btn-purple") }}
                            <a href="{{ url_for('resources.list') }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}