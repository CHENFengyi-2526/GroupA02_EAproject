{% extends "base.html.j2" %}

{% block title %}Edit Profile - ASP.NET Core Community{% endblock %}

{% block content %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3><i class="fas fa-user-edit me-2"></i>Edit Profile</h3>
                </div>
                <div class="card-body p-5">
                    <form method="POST">
                        {{ form.hidden_tag() }}

                        <div class="mb-3">
                            {{ form.username.label(class="form-label fw-semibold") }}
                            {{ form.username(class="form-control") }}
                            {% for error in form.username.errors %}
                                <div class="text-danger small">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <div class="mb-3">
                            {{ form.email.label(class="form-label fw-semibold") }}
                            {{ form.email(class="form-control") }}
                            {% for error in form.email.errors %}
                                <div class="text-danger small">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <div class="mb-4">
                            {{ form.bio.label(class="form-label fw-semibold") }}
                            {{ form.bio(class="form-control", rows=5) }}
                            {% for error in form.bio.errors %}
                                <div class="text-danger small">{{ error }}</div>
                            {% endfor %}
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ url_for('main.user_profile', username=current_user.username) }}" 
                               class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-purple btn-lg px-5">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}