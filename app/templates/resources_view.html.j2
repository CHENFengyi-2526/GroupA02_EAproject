{% extends "base.html.j2" %}

{% block title %}{{ resource.title }} - Resources{% endblock %}

{% block content %}
<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ url_for('resources.list') }}">Resources</a></li>
            <li class="breadcrumb-item active">{{ resource.title }}</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
                <h2 class="card-title">{{ resource.title }}</h2>
                <span class="badge bg-info fs-6">{{ resource.type|capitalize }}</span>
            </div>
            
            <p class="text-muted mt-3">
                <small>
                    <i class="fas fa-user me-1"></i> Uploaded by User #{{ resource.user_id }} |
                    <i class="fas fa-calendar me-1 ms-2"></i> {{ resource.created_at.strftime('%Y-%m-%d') if resource.created_at else 'Unknown' }} |
                    <i class="fas fa-download me-1 ms-2"></i> {{ resource.download_count }} downloads
                </small>
            </p>
            
            {% if resource.category %}
            <p>
                <small class="text-muted">Category: {{ resource.category.name }}</small>
            </p>
            {% endif %}
            
            <hr>
            
            <h5>Description</h5>
            <p class="mt-3">{{ resource.description or 'No description provided.' }}</p>
            
            <hr>
            
            <div class="mt-4">
                <a href="{{ url_for('resources.download', id=resource.id) }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-download me-2"></i>Download Resource
                </a>
                
                {% if current_user.is_authenticated and (current_user.id == resource.user_id or current_user.has_role('admin')) %}
                <a href="{{ url_for('resources.edit', id=resource.id) }}" class="btn btn-outline-warning btn-lg ms-2">
                    <i class="fas fa-edit me-2"></i>Edit
                </a>
                <button type="button" class="btn btn-outline-danger btn-lg ms-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
{% if current_user.is_authenticated and (current_user.id == resource.user_id or current_user.has_role('admin')) %}
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete "{{ resource.title }}"?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form action="{{ url_for('resources.delete', id=resource.id) }}" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}